{
  "name": "express-api-stress-tester",
  "version": "2.0.4",
  "description": "High-performance distributed API stress testing platform for Express.js APIs — simulate up to 10M concurrent virtual users",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "express-api-stress-tester": "src/cli.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --forceExit",
    "stress": "node src/cli.js"
  },
  "keywords": [
    "api",
    "stress-test",
    "load-test",
    "performance",
    "benchmark",
    "http",
    "concurrent",
    "undici",
    "express",
    "distributed",
    "load-testing",
    "worker-threads",
    "api-testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "csv-parse": "^5.6.0",
    "undici": "^6.24.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@jest/test-sequencer": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "README.md",
    "example-config.json",
    "examples/"
  ]
}

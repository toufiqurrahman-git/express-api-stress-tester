{
  "name": "express-api-stress-tester",
  "version": "1.0.0",
  "description": "High-performance API stress testing and load testing tool capable of simulating up to 100k concurrent users",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "express-api-stress-tester": "src/cli.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "stress": "node src/cli.js"
  },
  "keywords": [
    "api",
    "stress-test",
    "load-test",
    "performance",
    "benchmark",
    "http",
    "concurrent",
    "undici"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "undici": "^6.24.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@jest/test-sequencer": "^29.7.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [],
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src/",
    "README.md",
    "example-config.json"
  ]
}
